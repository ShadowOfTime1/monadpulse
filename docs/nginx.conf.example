# Rate limiting zone
limit_req_zone $binary_remote_addr zone=api:10m rate=30r/s;

server {
    server_name monadpulse.xyz www.monadpulse.xyz;

    root /var/www/monadpulse;
    index index.html;

    # Security headers
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' cdn.jsdelivr.net unpkg.com; style-src 'self' 'unsafe-inline' fonts.googleapis.com unpkg.com; font-src 'self' fonts.gstatic.com; img-src 'self' data: *.basemaps.cartocdn.com *.tile.openstreetmap.org; connect-src 'self'" always;

    # Slow-changing endpoints get a brief shared cache via headers — these
    # are aggregates over hours/days that don't shift second-to-second, so
    # 5-15 s of staleness is invisible to users but slashes load time on
    # cold-cache page loads. Realtime endpoints (default below) stay live.
    # Slow aggregates — request coalescing via proxy_cache_lock. 10k
    # concurrent identical hits collapse to 1 backend call; everyone else
    # waits up to 5s for the result, then reads from the in-memory cache.
    # X-Cache header (HIT/MISS/UPDATING) lets us verify behaviour live.
    location ~* ^/api/(dashboard/summary|validators/list|blocks/timeline|gas/hourly|health/scores)\b {
        limit_req zone=api burst=20 nodelay;
        proxy_cache api_cache;
        proxy_cache_key "$scheme$host$request_uri";
        proxy_cache_lock on;
        proxy_cache_lock_timeout 5s;
        proxy_cache_use_stale updating error timeout;
        proxy_cache_valid 200 5s;
        proxy_cache_background_update on;
        add_header X-Cache $upstream_cache_status always;
        add_header Cache-Control "public, max-age=5, stale-while-revalidate=10" always;
        # Strip /api/ prefix so backend (FastAPI registers routes without prefix)
        # sees /dashboard/summary, not /api/dashboard/summary. Required because
        # regex locations don't do the trailing-slash strip that prefix
        # locations do.
        rewrite ^/api/(.*)$ /$1 break;
        proxy_pass http://127.0.0.1:8890;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/ {
        limit_req zone=api burst=20 nodelay;
        # Realtime endpoints — 1s coalescing window. Invisible to users
        # (chain block time is 400ms; 1s lag is below human perception
        # for "live" UX), but at 10k concurrent users polling every 2s
        # this collapses ~5000 req/s to ~1 req/s on the backend.
        proxy_cache api_cache;
        proxy_cache_key "$scheme$host$request_uri";
        proxy_cache_lock on;
        proxy_cache_lock_timeout 2s;
        proxy_cache_use_stale updating error timeout;
        proxy_cache_valid 200 1s;
        proxy_cache_background_update on;
        add_header X-Cache $upstream_cache_status always;
        expires off;
        proxy_pass http://127.0.0.1:8890/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Block FastAPI docs
    location /api/docs { return 404; }
    location /api/redoc { return 404; }
    location /api/openapi.json { return 404; }

    # Static JS/CSS/SVG/fonts — long cache. Pages reference these with
    # ?v=<sha256_8> query strings (see scripts/deploy_assets.sh) so a
    # content change automatically forces a fresh download. Until then,
    # repeat visitors skip the network entirely.
    location ~* \.(js|css|svg|png|jpg|jpeg|gif|woff|woff2|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, max-age=31536000, immutable" always;
        # Reuse the security headers normally added by the server block —
        # these are not inherited inside a regex location, so we re-state.
        add_header X-Frame-Options "DENY" always;
        add_header X-Content-Type-Options "nosniff" always;
        try_files $uri =404;
    }

    location / {
        # No cache for HTML/JS/CSS — users always get latest deploy
        expires -1;
        # Clean URLs: /blocks → /blocks.html, /governance → /governance.html.
        # Falling back to /index.html silently rendered the dashboard for any
        # mistyped path (e.g. /blocks served the empty index).
        try_files $uri $uri.html $uri/ =404;
    }

    listen [::]:443 ssl ipv6only=on;
    listen 443 ssl;
    ssl_certificate /etc/letsencrypt/live/monadpulse.xyz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/monadpulse.xyz/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

server {
    if ($host = www.monadpulse.xyz) {
        return 301 https://$host$request_uri;
    }
    if ($host = monadpulse.xyz) {
        return 301 https://$host$request_uri;
    }
    listen 80;
    listen [::]:80;
    server_name monadpulse.xyz www.monadpulse.xyz;
    return 404;
}
